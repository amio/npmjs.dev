{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/package/(.*)",
      "headers": {
        "Location": "/$1"
      },
      "status": 307
    },
    {
      "src": "/api/engines/cloudflare",
      "dest": "/api/engines/cloudflare.js"
    },
    {
      "src": "/api/execute/cloudflare",
      "dest": "/api/execute/cloudflare.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
