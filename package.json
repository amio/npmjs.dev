{
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,green \"npm:dev:worker\" \"wait-on http-get://127.0.0.1:8787/api/engines/cloudflare && npm run dev:web\"",
    "dev:web": "vite",
    "dev:worker": "node ./scripts/dev-worker.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "preview:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint src vite.config.ts --react-plugin --jsx-a11y-plugin",
    "lint:fix": "oxlint src vite.config.ts --react-plugin --jsx-a11y-plugin --fix"
  },
  "dependencies": {
    "@cloudflare/worker-bundler": "^0.0.4",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@remixicon/react": "^4.6.0",
    "@types/dompurify": "^3.0.5",
    "@uiw/codemirror-theme-github": "^4.23.12",
    "@uiw/react-codemirror": "^4.23.12",
    "@webcontainer/api": "^1.6.1",
    "dompurify": "^3.3.3",
    "marked-react": "^3.0.0",
    "quickjs-emscripten": "^0.31.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-placeholder-loading": "^0.5.30"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild-wasm": "^0.25.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
    "vite-plugin-wasm": "^3.6.0",
    "wait-on": "^9.0.4",
    "wrangler": "^4.77.0"
  }
}
